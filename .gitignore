# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# env files (secrets — never commit)
.env
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Electron desktop build output (compiled binaries, not source)
/dist-electron

# logs and scratch files
*.log
serverlog.txt
supabase/.temp/

# one-off scratch scripts (not part of the app)
write_p1.py
write_p2.py
write_usermgmt.py
BUGFIX_PROMPT.md
