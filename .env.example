# Supabase Configuration
# Get these from: https://supabase.com → Your Project → Settings → API

# Your Supabase project URL (e.g. https://abcdefgh.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Your Supabase anon/public key
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Your Supabase service_role key (for admin operations like creating users)
# Get this from: Supabase Dashboard → Settings → API → service_role key
# WARNING: Never expose this key in the mobile app! Deliberately NOT prefixed
# with EXPO_PUBLIC_ so Expo/Metro never inlines it into the client bundle.
# Only used by server-side scripts (e.g. scripts/create-demo-accounts.js).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE
